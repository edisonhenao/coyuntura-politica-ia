# ============================================================
# Streamlit
# ============================================================
# Local secrets must never be committed.
.streamlit/secrets.toml
.streamlit/secrets.*.toml

# Keep the public template under version control.
!.streamlit/secrets.toml.example

# config.toml is intentionally NOT ignored because it contains
# non-secret UI/server configuration that should travel with the repo.

