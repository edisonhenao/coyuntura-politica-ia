# Copy this file to `.streamlit/secrets.toml` for local development:
#
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# Then replace the placeholder API key. Never commit the real
# `.streamlit/secrets.toml` file.

# ============================================================
# OpenAI credentials and models
# ============================================================
OPENAI_API_KEY = "sk-proj-replace-with-your-key"

OPENAI_TRANSCRIPTION_MODEL = "whisper-1"
OPENAI_ANALYSIS_MODEL = "gpt-5.6-luna"
OPENAI_API_TIMEOUT_S = 180

# ============================================================
# Audio sent to OpenAI
# ============================================================
# The app sends an M4A/AAC mono file at 16 kHz to OpenAI and keeps
# a temporary WAV only for the local Librosa analysis.
OPENAI_AUDIO_FILE_LIMIT_MB = 25
OPENAI_AUDIO_BITRATE_KBPS = 64
OPENAI_AUDIO_ESTIMATE_OVERHEAD_FACTOR = 1.07

# ============================================================
# Audio-analysis thresholds
# ============================================================
PAUSE_DRAMATIC_THRESHOLD_S = 1.5
ELONGATED_WORD_THRESHOLD_S = 0.6
LOW_CONFIDENCE_LOGPROB_THRESHOLD = -1.0
HIGH_COMPRESSION_RATIO_THRESHOLD = 2.4
HIGH_NO_SPEECH_PROB_THRESHOLD = 0.6

# ============================================================
# Pricing reference used by the technical summary
# Update these values if OpenAI changes its pricing.
# ============================================================
PRICING_REFERENCE_DATE = "2026-07-22"

WHISPER_PRICE_PER_MINUTE_USD = 0.006

# GPT-5.6 Luna - Standard, short context, USD per 1M tokens
GPT_SHORT_INPUT_PRICE_PER_1M = 1.00
GPT_SHORT_CACHED_INPUT_PRICE_PER_1M = 0.10
GPT_SHORT_CACHE_WRITE_PRICE_PER_1M = 1.25
GPT_SHORT_OUTPUT_PRICE_PER_1M = 6.00

# GPT-5.6 Luna - Standard, long context, USD per 1M tokens
GPT_LONG_INPUT_PRICE_PER_1M = 2.00
GPT_LONG_CACHED_INPUT_PRICE_PER_1M = 0.20
GPT_LONG_CACHE_WRITE_PRICE_PER_1M = 2.50
GPT_LONG_OUTPUT_PRICE_PER_1M = 9.00

GPT_LONG_CONTEXT_THRESHOLD_TOKENS = 272000
